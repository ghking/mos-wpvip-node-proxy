# Default (single-domain) configuration — copy to .env and fill in the values below.
# pnpm run dev loads this file automatically.

ORIGIN_URL=https://news.wingorigin.dev
SURFACE_SLUG=web

# Optional multi-domain mode — only if you need several hostnames in one process.
# Do NOT set these for the default single-domain setup.
# Pass --domain-map ./config/domain-map.json (see pnpm run dev:multi-domain) or uncomment:
# DOMAIN_MAP_FILE=./config/domain-map.json
#
# Per-domain MOS secret keys (names must match mosSecretKeyEnvVar in domain-map.json):
# MONETIZATION_OS_SECRET_KEY_WINGORIGIN=
# MONETIZATION_OS_SECRET_KEY_OTHER=

ANONYMOUS_SESSION_COOKIE_NAME=anon-session-id
AUTHENTICATED_USER_JWT_COOKIE_NAME=__session
INJECT_SCRIPT_URL=https://assets.monetizationos.com/web-components-latest.js
MONETIZATION_OS_ENDPOINTS_PREFIX=/mos-endpoints/
MONETIZATION_OS_HOST=https://api.monetizationos.com
SURFACE_DECISIONS_IGNORE_PATHS=
# Comma-separated regex patterns for cookie names forwarded to surface decisions (e.g. ^__session$, ^theme$).
SURFACE_DECISIONS_COOKIES=

# Optional JSON object string — merged into every origin request.
# vip @mos-testing-node.production config envvar set ORIGIN_REQUEST_HEADERS
# ORIGIN_REQUEST_HEADERS={"X-Api-Key": "secret"}

# Required — get this from the MOS dashboard and set it via:
# vip @mos-testing-node.production config envvar set MONETIZATION_OS_SECRET_KEY
MONETIZATION_OS_SECRET_KEY=

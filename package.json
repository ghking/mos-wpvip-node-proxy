{
    "name": "mos-testing-node",
    "version": "0.0.1",
    "description": "MonetizationOS Node.js proxy middleware for WordPress VIP",
    "packageManager": "pnpm@10.12.1",
    "scripts": {
        "build": "tsc --noEmit && esbuild src/server.ts src/index.ts --bundle --platform=node --format=cjs --outdir=dist --external:html-rewriter-wasm",
        "start": "node dist/server.js",
        "dev": "node --env-file=.env dist/server.js",
        "dev:multi-domain": "node --env-file=.env dist/server.js --domain-map ./config/domain-map.json",
        "test": "vitest run",
        "validate": "pnpm dlx @automattic/vip-go-preflight-checks"
    },
    "dependencies": {
        "@monetizationos/proxy": "1.5.0",
        "@types/node": "^25.9.1",
        "esbuild": "^0.28.0",
        "html-rewriter-wasm": "^0.4.1",
        "typescript": "^6.0.3"
    },
    "devDependencies": {
        "vitest": "^4.1.7"
    }
}
